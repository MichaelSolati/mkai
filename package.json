{
  "name": "mkai",
  "version": "0.1.0",
  "description": "AI Profile Loader - manage groups of agents, skills, and commands for multiple coding agents (Claude Code, Gemini CLI, etc)",
  "type": "module",
  "bin": {
    "mkai": "./bin/mkai.js"
  },
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/vitest",
    "lint": "gts lint",
    "fix": "gts fix",
    "postinstall": "npm run build && npm link --ignore-scripts"
  },
  "author": "Michael Solati <mkslt04@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/MichaelSolati/mkai.git"
  },
  "bugs": {
    "url": "https://github.com/MichaelSolati/mkai/issues"
  },
  "dependencies": {
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "ink": "^7.0.5",
    "ink-use-stdout-dimensions": "^1.0.5",
    "react": "^19.2.7",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/react": "^19.2.17",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "gts": "^7.0.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
