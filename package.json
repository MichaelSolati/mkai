{
  "name": "cpx",
  "version": "0.1.0",
  "description": "Claude Profile Loader - manage groups of agents, skills, and commands",
  "type": "module",
  "bin": {
    "cpx": "./bin/cpx.js"
  },
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/vitest",
    "lint": "gts lint",
    "fix": "gts fix",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "gts": "^7.0.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
